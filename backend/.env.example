# Render Environment Variables
# Copy these to your Render Dashboard

PORT=5000
MONGO_URI=mongodb+srv://... (Your MongoDB Atlas URI)
JWT_SECRET=super-secret-key
OPENAI_API_KEY=sk-...
REPLICATE_API_TOKEN=r8_...
ELEVENLABS_API_KEY=...

# Your Vercel Frontend URL (DO NOT end with a slash)
FRONTEND_URL=https://frontend-nine-alpha-28.vercel.app
NODE_ENV=production
